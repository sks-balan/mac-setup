alias lss='ls -ltra'
alias lsdot='ls -dl .[^.]* .'

# Podman as drop-in Docker replacement
alias docker='podman'

# Go to web projects root
alias web='cd ~/spear_development/web'

# Eject spear SSD (both spear and spear_development volumes)
alias eject-spear='if [ -d /Volumes/spear ]; then diskutil eject $(diskutil info /Volumes/spear | grep "Part of Whole" | awk '"'"'{print $NF}'"'"') && echo "Spear SSD ejected"; else echo "Spear SSD already ejected"; fi'

# Stop Podman and eject spear SSD
alias spear-stop='podman machine stop spear-dev 2>/dev/null || true && eject-spear'

# Sync mac-setup project to external SSD
# Snapshots live zsh configs into repo first, then rsyncs everything
alias sync-mac-setup='cp ~/.zshrc ~/projects/mac-setup/zsh/.zshrc && cp ~/.all_aliases ~/projects/mac-setup/zsh/.all_aliases && rsync -av ~/projects/mac-setup/ /Volumes/spear_development/logs/work/$SPEAR_USER/development/mac-setup/ && echo "Synced to spear_development"'
